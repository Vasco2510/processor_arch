// test_forwarding.mem — formato halfword (16 bits por línea)
0093  // addi x1, x0, 1       [low]
0010  //                       [high]
0113  // addi x2, x0, 2       [low]
0020  //                       [high]
81b3  // add  x3, x1, x2      [low]
0020  //                       [high]
8233  // add  x4, x3, x1      [low]
0011  //                       [high]
02b3  // add  x5, x4, x3      [low]
0032  //                       [high]
8333  // add  x6, x5, x4      [low]
0042  //                       [high]
0533  // add  x10, x6, x5     [low]
0053  //                       [high]
0063  // beq  x0, x0, 0       [low]
0000  //                       [high]
